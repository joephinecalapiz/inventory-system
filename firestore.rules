rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /*
     * Returns true when Firebase Authentication
     * has identified a signed-in user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /*
     * Returns true when the signed-in user has
     * a matching Firestore profile.
     */
    function userProfileExists() {
      return isSignedIn()
        && exists(
          /databases/$(database)/documents/users/$(request.auth.uid)
        );
    }

    /*
     * Returns the logged-in user's Firestore profile.
     */
    function currentUserProfile() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      ).data;
    }

    /*
     * Only ACTIVE accounts may use protected
     * inventory collections.
     */
    function isActiveUser() {
      return userProfileExists()
        && currentUserProfile().status == "ACTIVE";
    }

    /*
     * Checks whether the active user's role appears
     * inside the supplied list of allowed roles.
     */
    function hasRole(allowedRoles) {
      return isActiveUser()
        && currentUserProfile().role in allowedRoles;
    }
    /*
 * Checks whether the current account is a
 * Super Administrator.
 */
function isSuperAdmin() {
  return hasRole([
    "SUPERADMIN"
  ]);
}

/*
 * Checks whether the current account is an
 * Administrator.
 */
function isAdmin() {
  return hasRole([
    "ADMIN"
  ]);
}

/*
 * Valid roles that may be saved in a user profile.
 */
function isValidManagedRole(role) {
  return role in [
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF",
    "CASHIER",
    "AUDITOR"
  ];
}

/*
 * Valid account statuses.
 */
function isValidManagedStatus(status) {
  return status in [
    "ACTIVE",
    "INACTIVE",
    "SUSPENDED"
  ];
}

/*
 * Allows only access-related fields to change.
 *
 * Fields such as email and displayName cannot be
 * changed through this operation.
 */
function onlyUserAccessFieldsChanged() {
  return request.resource.data
    .diff(resource.data)
    .affectedKeys()
    .hasOnly([
      "role",
      "status",
      "updatedBy",
      "updatedAt"
    ]);
}

/*
 * Administrators may manage operational accounts,
 * but cannot manage or assign ADMIN or SUPERADMIN.
 */
function adminCanManageTargetUser() {
  return resource.data.role in [
      "INVENTORY_STAFF",
      "CASHIER",
      "AUDITOR"
    ]
    && request.resource.data.role in [
      "INVENTORY_STAFF",
      "CASHIER",
      "AUDITOR"
    ];
}
    
    

 match /users/{userId} {

  /*
   * Users may read their own profile.
   * Superadmin and Admin may read other profiles.
   */
  allow get: if isSignedIn()
    && (
      request.auth.uid == userId
      || hasRole([
        "SUPERADMIN",
        "ADMIN"
      ])
    );

  /*
   * Superadmin and Admin may list users for
   * the User Management page.
   */
  allow list: if hasRole([
    "SUPERADMIN",
    "ADMIN"
  ]);

  /*
   * Role and status updates.
   */
  allow update: if isActiveUser()

    /*
     * Administrators cannot change their own
     * role or status.
     */
    && request.auth.uid != userId

    /*
     * Do not allow unrelated user-profile
     * fields to be changed.
     */
    && onlyUserAccessFieldsChanged()

    /*
     * Validate the new values.
     */
    && isValidManagedRole(
      request.resource.data.role
    )

    && isValidManagedStatus(
      request.resource.data.status
    )

    /*
     * Record who performed the change.
     */
    && request.resource.data.updatedBy
      == request.auth.uid

    /*
     * The timestamp must come from Firestore.
     */
    && request.resource.data.updatedAt
      == request.time

    /*
     * Superadmin may manage other users.
     *
     * Admin may only manage operational roles.
     */
    && (
      isSuperAdmin()
      || (
        isAdmin()
        && adminCanManageTargetUser()
      )
    );

  /*
   * Account creation will be handled in
   * Phase 1F-3.
   *
   * Account deletion remains disabled.
   */
  allow create, delete: if false;
}
     
     
     
    /*
 * PRODUCT MASTER AND STOCK BALANCE HELPERS
 */
function canReadProducts() {
  return hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF",
    "CASHIER",
    "AUDITOR"
  ]);
}

function canManageProducts() {
  return hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF"
  ]);
}

function isValidProductStatusValue(value) {
  return value in [
    "ACTIVE",
    "INACTIVE"
  ];
}

function isValidProductMoneyValue(value) {
  return value is number
    && value >= 0
    && value <= 999999999;
}

function isValidOptionalProductCost(value) {
  return value == null
    || isValidProductMoneyValue(value);
}

function isValidProductWholeNumber(value) {
  return value is int
    && value >= 0
    && value <= 999999999;
}

function isValidOptionalProductSource(data) {
  return !data.keys().hasAny([
      "sourceProductId"
    ])
    || (
      data.sourceProductId is string
      && data.sourceProductId.size() >= 1
      && data.sourceProductId.size() <= 100
      && data.sourceProductId.matches(
        "^[A-Za-z0-9_-]+$"
      )
    );
}

function productCategorySnapshotMatches(data) {
  let category = get(
    /databases/$(database)/documents/categories/$(data.categoryCode)
  ).data;

  return category.status == "ACTIVE"
    && category.code == data.categoryCode
    && category.name == data.category
    && category.name == data.categoryName
    && category.barcodePrefix == data.barcodePrefix;
}

function productUnitSnapshotMatches(data) {
  let unit = get(
    /databases/$(database)/documents/units/$(data.unitCode)
  ).data;

  return unit.status == "ACTIVE"
    && unit.code == data.unitCode
    && unit.name == data.unitName
    && unit.abbreviation == data.unitAbbreviation;
}

function productBarcodeCounterMatchesCreate(data) {
  let counter = getAfter(
    /databases/$(database)/documents/barcodeCounters/$(data.barcodePrefix)
  ).data;

  return counter.categoryCode == data.categoryCode
    && counter.barcodePrefix == data.barcodePrefix
    && counter.lastSequence == data.barcodeSequence
    && counter.updatedBy == request.auth.uid
    && counter.updatedAt == request.time;
}

function productSourceReservationMatches(data, productId) {
  return !data.keys().hasAny([
      "sourceProductId"
    ])
    || (
      getAfter(
        /databases/$(database)/documents/productMasterReservations/$(data.sourceProductId)
      ).data.productId == productId
      && getAfter(
        /databases/$(database)/documents/productMasterReservations/$(data.sourceProductId)
      ).data.sku == data.sku
      && getAfter(
        /databases/$(database)/documents/productMasterReservations/$(data.sourceProductId)
      ).data.createdBy == request.auth.uid
      && getAfter(
        /databases/$(database)/documents/productMasterReservations/$(data.sourceProductId)
      ).data.createdAt == request.time
    );
}

function isValidNewProduct(data, productId) {
  return data.keys().hasOnly([
      "sourceProductId",
      "name",
      "sku",
      "description",
      "status",
      "category",
      "categoryName",
      "categoryCode",
      "categoryId",
      "barcodePrefix",
      "unitCode",
      "unitId",
      "unitName",
      "unitAbbreviation",
      "costPrice",
      "sellingPrice",
      "price",
      "quantity",
      "reorderLevel",
      "barcode",
      "barcodeSequence",
      "hasStockHistory",
      "stockMovementCount",
      "createdBy",
      "createdAt",
      "updatedBy",
      "updatedAt"
    ])
    && data.keys().hasAll([
      "name",
      "sku",
      "description",
      "status",
      "category",
      "categoryName",
      "categoryCode",
      "categoryId",
      "barcodePrefix",
      "unitCode",
      "unitId",
      "unitName",
      "unitAbbreviation",
      "costPrice",
      "sellingPrice",
      "price",
      "quantity",
      "reorderLevel",
      "barcode",
      "barcodeSequence",
      "hasStockHistory",
      "stockMovementCount",
      "createdBy",
      "createdAt",
      "updatedBy",
      "updatedAt"
    ])
    && isValidOptionalProductSource(data)
    && data.name is string
    && data.name.size() >= 2
    && data.name.size() <= 150
    && data.sku is string
    && data.sku.matches(
      "^[A-Z0-9][A-Z0-9#&._/ -]{1,49}$"
    )
    && data.description is string
    && data.description.size() <= 500
    && isValidProductStatusValue(data.status)
    && data.status == "ACTIVE"
    && data.category is string
    && data.category.size() >= 2
    && data.category.size() <= 150
    && data.categoryName == data.category
    && data.categoryCode is string
    && data.categoryCode.matches(
      "^[A-Z0-9_]{2,50}$"
    )
    && data.categoryId == data.categoryCode
    && data.barcodePrefix is string
    && data.barcodePrefix.matches(
      "^[0-9]{2}$"
    )
    && data.unitCode is string
    && data.unitCode.matches(
      "^[A-Z0-9_]{1,50}$"
    )
    && data.unitId == data.unitCode
    && data.unitName is string
    && data.unitName.size() >= 1
    && data.unitName.size() <= 100
    && data.unitAbbreviation is string
    && data.unitAbbreviation.matches(
      "^[A-Z0-9]{1,10}$"
    )
    && isValidOptionalProductCost(data.costPrice)
    && isValidProductMoneyValue(data.sellingPrice)
    && data.price == data.sellingPrice
    && isValidProductWholeNumber(data.quantity)
    && isValidProductWholeNumber(data.reorderLevel)
    && data.barcode is string
    && data.barcode.matches(
      "^[0-9]{12}$"
    )
    && data.barcode[0:2] == data.barcodePrefix
    && data.barcodeSequence is int
    && data.barcodeSequence >= 1
    && data.barcodeSequence <= 999999999
    && int(data.barcode[2:11]) == data.barcodeSequence
    && data.hasStockHistory == false
    && data.stockMovementCount == 0
    && data.createdBy == request.auth.uid
    && data.createdAt == request.time
    && data.updatedBy == request.auth.uid
    && data.updatedAt == request.time
    && productCategorySnapshotMatches(data)
    && productUnitSnapshotMatches(data)
    && productBarcodeCounterMatchesCreate(data)
    && productSourceReservationMatches(
      data,
      productId
    );
}

function isValidProductMasterUpdate() {
  return request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "name",
        "description",
        "costPrice",
        "sellingPrice",
        "price",
        "reorderLevel",
        "status",
        "updatedBy",
        "updatedAt"
      ])
    && request.resource.data.name is string
    && request.resource.data.name.size() >= 2
    && request.resource.data.name.size() <= 150
    && request.resource.data.description is string
    && request.resource.data.description.size() <= 500
    && isValidOptionalProductCost(
      request.resource.data.costPrice
    )
    && isValidProductMoneyValue(
      request.resource.data.sellingPrice
    )
    && request.resource.data.price
      == request.resource.data.sellingPrice
    && isValidProductWholeNumber(
      request.resource.data.reorderLevel
    )
    && isValidProductStatusValue(
      request.resource.data.status
    )
    && request.resource.data.updatedBy
      == request.auth.uid
    && request.resource.data.updatedAt
      == request.time;
}

function isValidProductUnitAssignment() {
  return request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "unitCode",
        "unitId",
        "unitName",
        "unitAbbreviation",
        "updatedBy",
        "updatedAt"
      ])
    && (
      resource.data.get(
        "unitCode",
        ""
      ) == ""
      || resource.data.get(
        "unitCode",
        ""
      ) == request.resource.data.unitCode
    )
    && request.resource.data.unitCode is string
    && request.resource.data.unitCode.matches(
      "^[A-Z0-9_]{1,50}$"
    )
    && request.resource.data.unitId
      == request.resource.data.unitCode
    && request.resource.data.unitName is string
    && request.resource.data.unitName.size() >= 1
    && request.resource.data.unitName.size() <= 100
    && request.resource.data.unitAbbreviation is string
    && request.resource.data.unitAbbreviation.matches(
      "^[A-Z0-9]{1,10}$"
    )
    && request.resource.data.updatedBy
      == request.auth.uid
    && request.resource.data.updatedAt
      == request.time
    && productUnitSnapshotMatches(
      request.resource.data
    );
}

function isValidProductSourceAssignment(productId) {
  return hasRole([
      "SUPERADMIN",
      "ADMIN"
    ])
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "sourceProductId",
        "sourceIdentityAssignedBy",
        "sourceIdentityAssignedAt",
        "updatedBy",
        "updatedAt"
      ])
    && resource.data.get(
      "sourceProductId",
      ""
    ) == ""
    && request.resource.data.sourceProductId
      is string
    && request.resource.data.sourceProductId.matches(
      "^[A-Za-z0-9_-]{1,100}$"
    )
    && request.resource.data.sourceIdentityAssignedBy
      == request.auth.uid
    && request.resource.data.sourceIdentityAssignedAt
      == request.time
    && request.resource.data.updatedBy
      == request.auth.uid
    && request.resource.data.updatedAt
      == request.time
    && getAfter(
      /databases/$(database)/documents/productMasterReservations/$(request.resource.data.sourceProductId)
    ).data.productId == productId
    && getAfter(
      /databases/$(database)/documents/productMasterReservations/$(request.resource.data.sourceProductId)
    ).data.sku == request.resource.data.sku;
}

function isValidProductMigrationUpdate() {
  return hasRole([
      "SUPERADMIN",
      "ADMIN"
    ])
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "status",
        "description",
        "costPrice",
        "sellingPrice",
        "price",
        "hasStockHistory",
        "stockMovementCount",
        "legacyMigrationVersion",
        "legacyMigratedBy",
        "legacyMigratedAt",
        "updatedBy",
        "updatedAt"
      ])
    && isValidProductStatusValue(
      request.resource.data.status
    )
    && request.resource.data.description is string
    && request.resource.data.description.size() <= 500
    && isValidOptionalProductCost(
      request.resource.data.costPrice
    )
    && isValidProductMoneyValue(
      request.resource.data.sellingPrice
    )
    && request.resource.data.price
      == request.resource.data.sellingPrice
    && request.resource.data.hasStockHistory is bool
    && request.resource.data.stockMovementCount is int
    && request.resource.data.stockMovementCount >= 0
    && request.resource.data.legacyMigrationVersion == 1
    && request.resource.data.legacyMigratedBy
      == request.auth.uid
    && request.resource.data.legacyMigratedAt
      == request.time
    && request.resource.data.updatedBy
      == request.auth.uid
    && request.resource.data.updatedAt
      == request.time;
}

function isValidProductStockUpdate() {
  return request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "quantity",
        "costPrice",
        "hasStockHistory",
        "stockMovementCount",
        "lastStockMovementId",
        "lastStockMovementType",
        "lastStockMovementReason",
        "lastStockMovementQuantity",
        "lastStockMovementUnitCost",
        "lastStockMovementAt",
        "updatedBy",
        "updatedAt"
      ])
    && isValidProductWholeNumber(
      resource.data.quantity
    )
    && isValidProductWholeNumber(
      request.resource.data.quantity
    )
    && request.resource.data.hasStockHistory == true
    && request.resource.data.stockMovementCount is int
    && request.resource.data.stockMovementCount
      == resource.data.get(
        "stockMovementCount",
        0
      ) + 1
    && request.resource.data.lastStockMovementId
      is string
    && request.resource.data.lastStockMovementId.matches(
      "^[A-Za-z0-9_-]{1,128}$"
    )
    && request.resource.data.lastStockMovementType in [
      "IN",
      "OUT"
    ]
    && request.resource.data.lastStockMovementReason
      is string
    && request.resource.data.lastStockMovementQuantity
      is int
    && request.resource.data.lastStockMovementQuantity >= 1
    && request.resource.data.lastStockMovementQuantity <= 999999999
    && request.resource.data.lastStockMovementUnitCost
      is number
    && request.resource.data.lastStockMovementUnitCost >= 0
    && request.resource.data.lastStockMovementUnitCost <= 999999999
    && request.resource.data.lastStockMovementAt
      == request.time
    && request.resource.data.updatedBy
      == request.auth.uid
    && request.resource.data.updatedAt
      == request.time
    && (
      (
        request.resource.data.lastStockMovementType == "IN"
        && request.resource.data.lastStockMovementReason in [
          "MANUAL_STOCK_IN",
          "PURCHASE_RECEIPT",
          "RETURNED_STOCK",
          "OPENING_BALANCE",
          "OTHER"
        ]
        && request.resource.data.quantity
          == resource.data.quantity
            + request.resource.data.lastStockMovementQuantity
      )
      ||
      (
        request.resource.data.lastStockMovementType == "OUT"
        && request.resource.data.lastStockMovementReason
          == "MANUAL_STOCK_OUT"
        && request.resource.data.quantity
          == resource.data.quantity
            - request.resource.data.lastStockMovementQuantity
        && request.resource.data.quantity >= 0
        && request.resource.data.lastStockMovementUnitCost == 0
      )
    )
    && (
      !request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasAny([
          "costPrice"
        ])
      || (
        request.resource.data.lastStockMovementType == "IN"
        && request.resource.data.lastStockMovementUnitCost > 0
        && request.resource.data.costPrice
          == request.resource.data.lastStockMovementUnitCost
      )
    );
}

match /products/{productId} {
  allow get, list: if canReadProducts();

  allow create: if canManageProducts()
    && isValidNewProduct(
      request.resource.data,
      productId
    );

  allow update: if canManageProducts()
    && (
      isValidProductMasterUpdate()
      || isValidProductUnitAssignment()
      || isValidProductSourceAssignment(
        productId
      )
      || isValidProductMigrationUpdate()
      || isValidProductStockUpdate()
    );

  allow delete: if hasRole([
      "SUPERADMIN",
      "ADMIN"
    ])
    && resource.data.quantity == 0
    && resource.data.get(
      "hasStockHistory",
      false
    ) == false
    && resource.data.get(
      "stockMovementCount",
      0
    ) == 0
    && resource.data.get(
      "sourceProductId",
      ""
    ) == "";
}

/*
 * PRODUCT MASTER SOURCE RESERVATIONS
 *
 * Prevents the same product-master record from
 * being added more than once.
 */
match /productMasterReservations/{sourceProductId} {

  allow get: if hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF"
  ]);

  /*
   * The application checks one specific
   * reservation document. Listing every
   * reservation is unnecessary.
   */
  allow list: if false;

  allow create: if hasRole([
      "SUPERADMIN",
      "ADMIN",
      "INVENTORY_STAFF"
    ])

    && request.resource.data.keys().hasOnly([
      "sourceProductId",
      "productId",
      "sku",
      "createdBy",
      "createdAt"
    ])

    && request.resource.data.keys().hasAll([
      "sourceProductId",
      "productId",
      "sku",
      "createdBy",
      "createdAt"
    ])

    && request.resource.data.sourceProductId
      == sourceProductId

    && request.resource.data.sourceProductId
      is string

    && request.resource.data.sourceProductId.size()
      >= 1

    && request.resource.data.sourceProductId.size()
      <= 100

    && request.resource.data.sourceProductId.matches(
      "^[A-Za-z0-9_-]+$"
    )

    && request.resource.data.productId
      is string

    && request.resource.data.productId.size()
      >= 1

    && request.resource.data.productId.size()
      <= 128

    && request.resource.data.sku
      is string

    && request.resource.data.sku.size()
      >= 2

    && request.resource.data.sku.size()
      <= 50

    && request.resource.data.createdBy
      == request.auth.uid

    && request.resource.data.createdAt
      == request.time

    && getAfter(
      /databases/$(database)/documents/products/$(request.resource.data.productId)
    ).data.sourceProductId == sourceProductId

    && getAfter(
      /databases/$(database)/documents/products/$(request.resource.data.productId)
    ).data.sku == request.resource.data.sku;

  /*
   * Reservations are permanent.
   */
  allow update, delete: if false;
}





    /*
     * BARCODE COUNTERS
     */
    match /barcodeCounters/{barcodePrefix} {
  allow get: if canManageProducts();
  allow list: if false;

  allow create: if canManageProducts()
    && request.resource.data.keys().hasOnly([
      "category",
      "categoryCode",
      "barcodePrefix",
      "lastSequence",
      "updatedBy",
      "updatedAt"
    ])
    && request.resource.data.keys().hasAll([
      "category",
      "categoryCode",
      "barcodePrefix",
      "lastSequence",
      "updatedBy",
      "updatedAt"
    ])
    && request.resource.data.barcodePrefix
      == barcodePrefix
    && request.resource.data.categoryCode.matches(
      "^[A-Z0-9_]{2,50}$"
    )
    && request.resource.data.category is string
    && request.resource.data.category.size() >= 2
    && request.resource.data.category.size() <= 150
    && request.resource.data.barcodePrefix.matches(
      "^[0-9]{2}$"
    )
    && request.resource.data.lastSequence == 1
    && request.resource.data.updatedBy
      == request.auth.uid
    && request.resource.data.updatedAt
      == request.time
    && get(
      /databases/$(database)/documents/categories/$(request.resource.data.categoryCode)
    ).data.status == "ACTIVE"
    && get(
      /databases/$(database)/documents/categories/$(request.resource.data.categoryCode)
    ).data.name == request.resource.data.category
    && get(
      /databases/$(database)/documents/categories/$(request.resource.data.categoryCode)
    ).data.barcodePrefix
      == request.resource.data.barcodePrefix;

  allow update: if canManageProducts()
    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "lastSequence",
        "updatedBy",
        "updatedAt"
      ])
    && request.resource.data.category
      == resource.data.category
    && request.resource.data.categoryCode
      == resource.data.categoryCode
    && request.resource.data.barcodePrefix
      == resource.data.barcodePrefix
    && request.resource.data.lastSequence is int
    && request.resource.data.lastSequence
      == resource.data.lastSequence + 1
    && request.resource.data.lastSequence
      <= 999999999
    && request.resource.data.updatedBy
      == request.auth.uid
    && request.resource.data.updatedAt
      == request.time;

  allow delete: if false;
}

    /*
     * STOCK MOVEMENT HISTORY
     */
    /*
 * STOCK MOVEMENT VALIDATION
 */
function hasValidStockMovementSnapshots(data) {
  return (
      !data.keys().hasAny([
        "barcode"
      ])
      || (
        data.barcode is string
        && data.barcode.size() <= 100
      )
    )
    && (
      !data.keys().hasAny([
        "category"
      ])
      || (
        data.category is string
        && data.category.size() <= 150
      )
    )
    && (
      !data.keys().hasAny([
        "categoryCode"
      ])
      || (
        data.categoryCode is string
        && data.categoryCode.size() <= 50
      )
    )
    && (
      !data.keys().hasAny([
        "unitCode"
      ])
      || (
        data.unitCode is string
        && data.unitCode.size() <= 50
      )
    )
    && (
      !data.keys().hasAny([
        "unitName"
      ])
      || (
        data.unitName is string
        && data.unitName.size() <= 100
      )
    )
    && (
      !data.keys().hasAny([
        "unitAbbreviation"
      ])
      || (
        data.unitAbbreviation is string
        && data.unitAbbreviation.size() <= 10
      )
    )
    && (
      !data.keys().hasAny([
        "remarks"
      ])
      || (
        data.remarks is string
        && data.remarks.size() <= 500
      )
    );
}

function isValidManualStockInMovement(data, movementId) {
  return data.keys().hasOnly([
      "movementId",
      "operationId",
      "movementType",
      "reason",
      "productId",
      "productName",
      "productSku",
      "quantity",
      "previousQuantity",
      "newQuantity",
      "unitCost",
      "totalCost",
      "source",
      "referenceNumber",
      "dateReceived",
      "receivedBy",
      "receivedByName",
      "createdBy",
      "createdAt",
      "barcode",
      "category",
      "categoryCode",
      "unitCode",
      "unitName",
      "unitAbbreviation",
      "remarks"
    ])
    && data.keys().hasAll([
      "movementId",
      "operationId",
      "movementType",
      "reason",
      "productId",
      "productName",
      "productSku",
      "quantity",
      "previousQuantity",
      "newQuantity",
      "unitCost",
      "totalCost",
      "source",
      "referenceNumber",
      "dateReceived",
      "receivedBy",
      "receivedByName",
      "createdBy",
      "createdAt"
    ])
    && data.movementId == movementId
    && data.operationId == movementId
    && data.operationId.matches(
      "^[A-Za-z0-9_-]{16,128}$"
    )
    && data.movementType == "IN"
    && data.reason in [
      "MANUAL_STOCK_IN",
      "RETURNED_STOCK",
      "OPENING_BALANCE",
      "OTHER"
    ]
    && data.productId is string
    && data.productId.size() >= 1
    && data.productName is string
    && data.productName.size() >= 1
    && data.productName.size() <= 150
    && data.productSku is string
    && data.productSku.size() >= 2
    && data.productSku.size() <= 50
    && data.quantity is int
    && data.quantity >= 1
    && data.quantity <= 999999999
    && data.previousQuantity is int
    && data.previousQuantity >= 0
    && data.newQuantity
      == data.previousQuantity + data.quantity
    && data.unitCost is number
    && data.unitCost >= 0
    && data.unitCost <= 999999999
    && data.totalCost is number
    && data.totalCost <= 999999999999.99
    && data.totalCost >= data.quantity * data.unitCost - 0.01
    && data.totalCost <= data.quantity * data.unitCost + 0.01
    && data.source is string
    && data.source.size() >= 1
    && data.source.size() <= 150
    && data.referenceNumber is string
    && data.referenceNumber.size() <= 100
    && data.dateReceived is timestamp
    && data.receivedBy == request.auth.uid
    && data.receivedByName is string
    && data.receivedByName.size() >= 1
    && data.receivedByName.size() <= 150
    && data.createdBy == request.auth.uid
    && data.createdAt == request.time
    && hasValidStockMovementSnapshots(data);
}

function isValidPurchaseReceiptMovement(data, movementId) {
  return data.keys().hasOnly([
      "movementId",
      "movementType",
      "reason",
      "productId",
      "productName",
      "productSku",
      "quantity",
      "previousQuantity",
      "newQuantity",
      "unitCost",
      "totalCost",
      "source",
      "referenceNumber",
      "dateReceived",
      "receivedBy",
      "receivedByName",
      "purchaseOrderId",
      "poNumber",
      "goodsReceiptId",
      "goodsReceiptNumber",
      "createdBy",
      "createdAt",
      "barcode",
      "category",
      "categoryCode",
      "unitCode",
      "unitName",
      "unitAbbreviation",
      "remarks"
    ])
    && data.keys().hasAll([
      "movementId",
      "movementType",
      "reason",
      "productId",
      "productName",
      "productSku",
      "quantity",
      "previousQuantity",
      "newQuantity",
      "unitCost",
      "totalCost",
      "source",
      "referenceNumber",
      "dateReceived",
      "receivedBy",
      "receivedByName",
      "purchaseOrderId",
      "poNumber",
      "goodsReceiptId",
      "goodsReceiptNumber",
      "createdBy",
      "createdAt"
    ])
    && data.movementId == movementId
    && data.movementId.matches(
      "^[A-Za-z0-9_-]{1,128}$"
    )
    && data.movementType == "IN"
    && data.reason == "PURCHASE_RECEIPT"
    && data.productId is string
    && data.productId.size() >= 1
    && data.productName is string
    && data.productName.size() >= 1
    && data.productName.size() <= 150
    && data.productSku is string
    && data.productSku.size() >= 2
    && data.productSku.size() <= 50
    && data.quantity is int
    && data.quantity >= 1
    && data.quantity <= 999999999
    && data.previousQuantity is int
    && data.previousQuantity >= 0
    && data.newQuantity
      == data.previousQuantity + data.quantity
    && data.unitCost is number
    && data.unitCost >= 0
    && data.unitCost <= 999999999
    && data.totalCost is number
    && data.totalCost <= 999999999999.99
    && data.totalCost >= data.quantity * data.unitCost - 0.01
    && data.totalCost <= data.quantity * data.unitCost + 0.01
    && data.source is string
    && data.source.size() >= 1
    && data.source.size() <= 150
    && data.referenceNumber is string
    && data.referenceNumber.size() >= 1
    && data.referenceNumber.size() <= 100
    && data.dateReceived is timestamp
    && data.receivedBy == request.auth.uid
    && data.receivedByName is string
    && data.receivedByName.size() >= 1
    && data.receivedByName.size() <= 150
    && data.purchaseOrderId is string
    && data.purchaseOrderId.size() >= 1
    && data.poNumber.matches(
      "^PO-[0-9]{4}-[0-9]{6}$"
    )
    && data.goodsReceiptId is string
    && data.goodsReceiptId.size() >= 1
    && data.goodsReceiptNumber.matches(
      "^GRN-[0-9]{4}-[0-9]{6}$"
    )
    && data.createdBy == request.auth.uid
    && data.createdAt == request.time
    && hasValidStockMovementSnapshots(data);
}

function isValidManualStockOutMovement(data, movementId) {
  return data.keys().hasOnly([
      "movementId",
      "productId",
      "productName",
      "productSku",
      "movementType",
      "reason",
      "quantity",
      "previousQuantity",
      "newQuantity",
      "categoryCode",
      "unitCode",
      "unitAbbreviation",
      "createdBy",
      "createdAt"
    ])
    && data.keys().hasAll([
      "movementId",
      "productId",
      "productName",
      "productSku",
      "movementType",
      "reason",
      "quantity",
      "previousQuantity",
      "newQuantity",
      "createdBy",
      "createdAt"
    ])
    && data.movementId == movementId
    && data.movementId.matches(
      "^[A-Za-z0-9_-]{1,128}$"
    )
    && data.movementType == "OUT"
    && data.reason == "MANUAL_STOCK_OUT"
    && data.productId is string
    && data.productId.size() >= 1
    && data.productName is string
    && data.productName.size() >= 1
    && data.productName.size() <= 150
    && data.productSku is string
    && data.productSku.size() >= 2
    && data.productSku.size() <= 50
    && data.quantity is int
    && data.quantity >= 1
    && data.quantity <= 999999999
    && data.previousQuantity is int
    && data.previousQuantity >= data.quantity
    && data.newQuantity
      == data.previousQuantity - data.quantity
    && data.createdBy == request.auth.uid
    && data.createdAt == request.time
    && hasValidStockMovementSnapshots(data);
}

match /stockMovements/{movementId} {
  allow get, list: if hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF",
    "AUDITOR"
  ]);

  allow create: if hasRole([
      "SUPERADMIN",
      "ADMIN",
      "INVENTORY_STAFF"
    ])
    && (
      isValidManualStockInMovement(
        request.resource.data,
        movementId
      )
      || isValidPurchaseReceiptMovement(
        request.resource.data,
        movementId
      )
      || isValidManualStockOutMovement(
        request.resource.data,
        movementId
      )
    );

  allow update, delete: if false;
}

function stockInMovementMatchesOperation(
  data,
  operationId
) {
  let movement = getAfter(
    /databases/$(database)/documents/stockMovements/$(operationId)
  ).data;

  return movement.operationId == operationId
    && movement.movementId == operationId
    && movement.productId == data.productId
    && movement.productName == data.productName
    && movement.productSku == data.productSku
    && movement.quantity == data.quantityReceived
    && movement.previousQuantity == data.previousQuantity
    && movement.newQuantity == data.newQuantity
    && movement.unitCost == data.unitCost
    && movement.totalCost == data.totalCost
    && movement.source == data.source
    && movement.referenceNumber == data.referenceNumber
    && movement.dateReceived == data.dateReceived
    && movement.reason == data.reason
    && movement.get(
      "remarks",
      ""
    ) == data.remarks
    && movement.receivedBy == request.auth.uid
    && movement.receivedByName == data.receivedByName
    && movement.createdBy == request.auth.uid
    && movement.createdAt == request.time;
}

match /stockInOperations/{operationId} {
  allow get: if hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF"
  ]);
  allow list: if false;

  allow create: if hasRole([
      "SUPERADMIN",
      "ADMIN",
      "INVENTORY_STAFF"
    ])
    && operationId.matches(
      "^[A-Za-z0-9_-]{16,128}$"
    )
    && request.resource.data.keys().hasOnly([
      "operationId",
      "status",
      "movementId",
      "productId",
      "productName",
      "productSku",
      "quantityReceived",
      "previousQuantity",
      "newQuantity",
      "unitCost",
      "totalCost",
      "source",
      "referenceNumber",
      "dateReceived",
      "dateReceivedKey",
      "reason",
      "remarks",
      "receivedBy",
      "receivedByName",
      "createdBy",
      "createdAt"
    ])
    && request.resource.data.keys().hasAll([
      "operationId",
      "status",
      "movementId",
      "productId",
      "productName",
      "productSku",
      "quantityReceived",
      "previousQuantity",
      "newQuantity",
      "unitCost",
      "totalCost",
      "source",
      "referenceNumber",
      "dateReceived",
      "dateReceivedKey",
      "reason",
      "remarks",
      "receivedBy",
      "receivedByName",
      "createdBy",
      "createdAt"
    ])
    && request.resource.data.operationId == operationId
    && request.resource.data.status == "COMPLETED"
    && request.resource.data.movementId == operationId
    && request.resource.data.quantityReceived is int
    && request.resource.data.quantityReceived >= 1
    && request.resource.data.previousQuantity is int
    && request.resource.data.previousQuantity >= 0
    && request.resource.data.newQuantity
      == request.resource.data.previousQuantity
        + request.resource.data.quantityReceived
    && request.resource.data.unitCost is number
    && request.resource.data.unitCost >= 0
    && request.resource.data.totalCost is number
    && request.resource.data.totalCost <= 999999999999.99
    && request.resource.data.totalCost
      >= request.resource.data.quantityReceived
        * request.resource.data.unitCost - 0.01
    && request.resource.data.totalCost
      <= request.resource.data.quantityReceived
        * request.resource.data.unitCost + 0.01
    && request.resource.data.source is string
    && request.resource.data.source.size() >= 1
    && request.resource.data.source.size() <= 150
    && request.resource.data.referenceNumber is string
    && request.resource.data.referenceNumber.size() <= 100
    && request.resource.data.dateReceived is timestamp
    && request.resource.data.dateReceivedKey.matches(
      "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    )
    && request.resource.data.reason in [
      "MANUAL_STOCK_IN",
      "RETURNED_STOCK",
      "OPENING_BALANCE",
      "OTHER"
    ]
    && request.resource.data.remarks is string
    && request.resource.data.remarks.size() <= 500
    && request.resource.data.receivedBy
      == request.auth.uid
    && request.resource.data.receivedByName is string
    && request.resource.data.receivedByName.size() >= 1
    && request.resource.data.receivedByName.size() <= 150
    && request.resource.data.createdBy
      == request.auth.uid
    && request.resource.data.createdAt
      == request.time
    && stockInMovementMatchesOperation(
      request.resource.data,
      operationId
    );

  allow update, delete: if false;
}

    /*
 * CATEGORY MASTER DATA
 */
match /categories/{categoryId} {

  /*
   * These roles may view category records.
   */
  allow get, list: if hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF",
    "AUDITOR"
  ]);

  /*
   * Only Superadmin and Admin may create
   * category records.
   */
  allow create: if hasRole([
      "SUPERADMIN",
      "ADMIN"
    ])

    && request.resource.data.keys().hasOnly([
      "name",
      "code",
      "barcodePrefix",
      "description",
      "status",
      "createdBy",
      "createdAt",
      "updatedBy",
      "updatedAt"
    ])

    && request.resource.data.keys().hasAll([
      "name",
      "code",
      "barcodePrefix",
      "description",
      "status",
      "createdBy",
      "createdAt",
      "updatedBy",
      "updatedAt"
    ])

    && request.resource.data.name is string
    && request.resource.data.name.size() >= 2
    && request.resource.data.name.size() <= 100

    && request.resource.data.code is string
    && request.resource.data.code == categoryId
    && request.resource.data.code.size() >= 2
    && request.resource.data.code.size() <= 50
    && request.resource.data.code.matches(
      "^[A-Z0-9_]+$"
    )

    && request.resource.data.barcodePrefix is string
    && request.resource.data.barcodePrefix.matches(
      "^[0-9]{2}$"
    )

    && request.resource.data.description is string
    && request.resource.data.description.size() <= 500

    && request.resource.data.status in [
      "ACTIVE",
      "INACTIVE"
    ]

    && request.resource.data.createdBy
      == request.auth.uid

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.createdAt
      == request.time

    && request.resource.data.updatedAt
      == request.time;

  /*
   * Only editable fields may change.
   *
   * Category code and barcode prefix remain
   * permanent after creation.
   */
  allow update: if hasRole([
      "SUPERADMIN",
      "ADMIN"
    ])

    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "name",
        "description",
        "status",
        "updatedBy",
        "updatedAt"
      ])

    && request.resource.data.code
      == resource.data.code

    && request.resource.data.barcodePrefix
      == resource.data.barcodePrefix

    && request.resource.data.createdBy
      == resource.data.createdBy

    && request.resource.data.createdAt
      == resource.data.createdAt

    && request.resource.data.name is string
    && request.resource.data.name.size() >= 2
    && request.resource.data.name.size() <= 100

    && request.resource.data.description is string
    && request.resource.data.description.size() <= 500

    && request.resource.data.status in [
      "ACTIVE",
      "INACTIVE"
    ]

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time;

  /*
   * Categories should be deactivated rather
   * than permanently deleted.
   */
  allow delete: if false;
}


/*
 * CATEGORY BARCODE PREFIX RESERVATIONS
 */
match /categoryBarcodePrefixes/{barcodePrefix} {

  /*
   * The category creation transaction checks
   * whether the selected prefix already exists.
   */
  allow get: if hasRole([
    "SUPERADMIN",
    "ADMIN"
  ]);

  allow list: if false;

  /*
   * Reserve a prefix when its category is created.
   */
  allow create: if hasRole([
      "SUPERADMIN",
      "ADMIN"
    ])

    && request.resource.data.keys().hasOnly([
      "barcodePrefix",
      "categoryCode",
      "createdBy",
      "createdAt"
    ])

    && request.resource.data.keys().hasAll([
      "barcodePrefix",
      "categoryCode",
      "createdBy",
      "createdAt"
    ])

    && request.resource.data.barcodePrefix
      == barcodePrefix

    && request.resource.data.barcodePrefix is string

    && request.resource.data.barcodePrefix.matches(
      "^[0-9]{2}$"
    )

    && request.resource.data.categoryCode is string

    && request.resource.data.categoryCode.matches(
      "^[A-Z0-9_]+$"
    )

    && request.resource.data.createdBy
      == request.auth.uid

    && request.resource.data.createdAt
      == request.time;

  /*
   * Prefix reservations remain permanent so an
   * existing barcode prefix cannot be reused.
   */
  allow update, delete: if false;
}

/*
 * UNIT OF MEASUREMENT MASTER DATA
 */
match /units/{unitId} {

  /*
   * Inventory Staff and Auditor may view units
   * but cannot manage them.
   */
  allow get, list: if hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF",
    "AUDITOR"
  ]);

  /*
   * Only Superadmin and Admin may create units.
   */
  allow create: if hasRole([
      "SUPERADMIN",
      "ADMIN"
    ])

    && request.resource.data.keys().hasOnly([
      "name",
      "code",
      "abbreviation",
      "description",
      "status",
      "createdBy",
      "createdAt",
      "updatedBy",
      "updatedAt"
    ])

    && request.resource.data.keys().hasAll([
      "name",
      "code",
      "abbreviation",
      "description",
      "status",
      "createdBy",
      "createdAt",
      "updatedBy",
      "updatedAt"
    ])

    && request.resource.data.name is string
    && request.resource.data.name.size() >= 2
    && request.resource.data.name.size() <= 100

    && request.resource.data.code is string
    && request.resource.data.code == unitId
    && request.resource.data.code.size() >= 2
    && request.resource.data.code.size() <= 50
    && request.resource.data.code.matches(
      "^[A-Z0-9_]+$"
    )

    && request.resource.data.abbreviation is string
    && request.resource.data.abbreviation.matches(
      "^[A-Z0-9]{1,10}$"
    )

    && request.resource.data.description is string
    && request.resource.data.description.size() <= 500

    && request.resource.data.status in [
      "ACTIVE",
      "INACTIVE"
    ]

    && request.resource.data.createdBy
      == request.auth.uid

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.createdAt
      == request.time

    && request.resource.data.updatedAt
      == request.time;

  /*
   * The unit code and abbreviation remain
   * permanent after the unit is created.
   */
  allow update: if hasRole([
      "SUPERADMIN",
      "ADMIN"
    ])

    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "name",
        "description",
        "status",
        "updatedBy",
        "updatedAt"
      ])

    && request.resource.data.code
      == resource.data.code

    && request.resource.data.abbreviation
      == resource.data.abbreviation

    && request.resource.data.createdBy
      == resource.data.createdBy

    && request.resource.data.createdAt
      == resource.data.createdAt

    && request.resource.data.name is string
    && request.resource.data.name.size() >= 2
    && request.resource.data.name.size() <= 100

    && request.resource.data.description is string
    && request.resource.data.description.size() <= 500

    && request.resource.data.status in [
      "ACTIVE",
      "INACTIVE"
    ]

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time;

  /*
   * Units should be deactivated instead of
   * permanently deleted.
   */
  allow delete: if false;
}


/*
 * UNIT ABBREVIATION RESERVATIONS
 *
 * This collection prevents duplicate unit
 * abbreviations such as two units using PCS.
 */
match /unitAbbreviations/{unitAbbreviation} {

  /*
   * The create-unit transaction checks whether
   * the abbreviation is already reserved.
   */
  allow get: if hasRole([
    "SUPERADMIN",
    "ADMIN"
  ]);

  allow list: if false;

  /*
   * Reserve an abbreviation when a unit is
   * created.
   */
  allow create: if hasRole([
      "SUPERADMIN",
      "ADMIN"
    ])

    && request.resource.data.keys().hasOnly([
      "abbreviation",
      "unitCode",
      "createdBy",
      "createdAt"
    ])

    && request.resource.data.keys().hasAll([
      "abbreviation",
      "unitCode",
      "createdBy",
      "createdAt"
    ])

    && request.resource.data.abbreviation
      == unitAbbreviation

    && request.resource.data.abbreviation
      is string

    && request.resource.data.abbreviation.matches(
      "^[A-Z0-9]{1,10}$"
    )

    && request.resource.data.unitCode
      is string

    && request.resource.data.unitCode.matches(
      "^[A-Z0-9_]+$"
    )

    && request.resource.data.createdBy
      == request.auth.uid

    && request.resource.data.createdAt
      == request.time;

  /*
   * Abbreviation reservations remain permanent
   * so previously assigned abbreviations cannot
   * be reused.
   */
  allow update, delete: if false;
}


/*
 * Supplier access helpers.
 */
function isSupplierManager() {
  return hasRole([
    "SUPERADMIN",
    "ADMIN"
  ]);
}

function canReadSuppliers() {
  return hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF",
    "AUDITOR"
  ]);
}

function canUpdateSupplierPurchaseHistory() {
  return hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF"
  ]);
}

function isValidSupplierStatus(status) {
  return status in [
    "ACTIVE",
    "INACTIVE"
  ];
}

function isValidSupplierPaymentTerm(paymentTerm) {
  return paymentTerm in [
    "CASH_ON_DELIVERY",
    "PREPAID",
    "NET_7",
    "NET_15",
    "NET_30",
    "NET_45",
    "NET_60",
    "CUSTOM"
  ];
}

function isValidSupplierData(data) {
  return data.supplierCode is string
    && data.supplierCode.matches(
      "^SUP-[0-9]{6}$"
    )

    && data.name is string
    && data.name.size() >= 2
    && data.name.size() <= 150

    && data.nameNormalized is string
    && data.nameNormalized.size() >= 2
    && data.nameNormalized.size() <= 150

    && data.contactPerson is string
    && data.contactPerson.size() <= 100

    && data.contactNumber is string
    && data.contactNumber.size() <= 30
    && data.contactNumber.matches(
      "^[0-9+(). -]*$"
    )

    && data.email is string
    && data.email.size() <= 150
    && (
      data.email == ""
      || data.email.matches(
        "^[^@ ]+@[^@ ]+[.][^@ ]+$"
      )
    )

    && data.address is string
    && data.address.size() <= 300

    && data.tin is string
    && data.tin.size() <= 50
    && data.tin.matches(
      "^[A-Za-z0-9 -]*$"
    )

    && isValidSupplierPaymentTerm(
      data.paymentTerm
    )

    && data.customPaymentTerms is string
    && data.customPaymentTerms.size() <= 100

    && (
      (
        data.paymentTerm == "CUSTOM"
        && data.customPaymentTerms.size() >= 1
      )
      ||
      (
        data.paymentTerm != "CUSTOM"
        && data.customPaymentTerms == ""
      )
    )

    && data.notes is string
    && data.notes.size() <= 500

    && isValidSupplierStatus(
      data.status
    )

    && data.hasPurchaseHistory is bool

    && data.purchaseOrderCount is int
    && data.purchaseOrderCount >= 0

    && data.createdBy is string
    && data.createdBy.size() >= 1

    && data.updatedBy is string
    && data.updatedBy.size() >= 1;
}

function onlySupplierMasterFieldsChanged() {
  return request.resource.data
    .diff(resource.data)
    .affectedKeys()
    .hasOnly([
      "name",
      "nameNormalized",
      "contactPerson",
      "contactNumber",
      "email",
      "address",
      "tin",
      "paymentTerm",
      "customPaymentTerms",
      "notes",
      "updatedBy",
      "updatedAt"
    ]);
}

function onlySupplierStatusFieldsChanged() {
  return request.resource.data
    .diff(resource.data)
    .affectedKeys()
    .hasOnly([
      "status",
      "statusChangedBy",
      "statusChangedAt",
      "updatedBy",
      "updatedAt"
    ]);
}

function onlySupplierPurchaseHistoryFieldsChanged() {
  return request.resource.data
    .diff(resource.data)
    .affectedKeys()
    .hasOnly([
      "hasPurchaseHistory",
      "purchaseOrderCount",
      "lastPurchaseOrderId",
      "lastPurchaseOrderNumber",
      "lastPurchaseOrderSubmittedAt",
      "updatedBy",
      "updatedAt"
    ]);
}

function submittedPurchaseOrderMatchesSupplier(
  supplierId,
  purchaseOrderId,
  poNumber
) {
  let purchaseOrderAfter = getAfter(
    /databases/$(database)/documents/purchaseOrders/$(purchaseOrderId)
  ).data;

  return purchaseOrderAfter.status == "SUBMITTED"
    && purchaseOrderAfter.supplierId == supplierId
    && purchaseOrderAfter.poNumber == poNumber
    && purchaseOrderAfter.submittedBy == request.auth.uid
    && purchaseOrderAfter.submittedAt == request.time;
}

/*
 * SUPPLIER MASTER DATA
 */
match /suppliers/{supplierId} {

  /*
   * Superadmin, Admin, Inventory Staff,
   * and Auditor may view supplier records.
   */
  allow get, list: if canReadSuppliers();

  /*
   * Only Superadmin and Admin may create
   * supplier records.
   */
  allow create: if isSupplierManager()

    && request.resource.data.keys().hasOnly([
      "supplierCode",
      "name",
      "nameNormalized",
      "contactPerson",
      "contactNumber",
      "email",
      "address",
      "tin",
      "paymentTerm",
      "customPaymentTerms",
      "notes",
      "status",
      "hasPurchaseHistory",
      "purchaseOrderCount",
      "createdBy",
      "createdAt",
      "updatedBy",
      "updatedAt"
    ])

    && request.resource.data.keys().hasAll([
      "supplierCode",
      "name",
      "nameNormalized",
      "contactPerson",
      "contactNumber",
      "email",
      "address",
      "tin",
      "paymentTerm",
      "customPaymentTerms",
      "notes",
      "status",
      "hasPurchaseHistory",
      "purchaseOrderCount",
      "createdBy",
      "createdAt",
      "updatedBy",
      "updatedAt"
    ])

    && isValidSupplierData(
      request.resource.data
    )

    && request.resource.data.status
      == "ACTIVE"

    && request.resource.data.hasPurchaseHistory
      == false

    && request.resource.data.purchaseOrderCount
      == 0

    && request.resource.data.createdBy
      == request.auth.uid

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.createdAt
      == request.time

    && request.resource.data.updatedAt
      == request.time

    /*
     * Supplier creation must also update the
     * supplier number counter in the same batch
     * or transaction.
     */
    && getAfter(
      /databases/$(database)/documents/supplierCounters/default
    ).data.updatedBy == request.auth.uid

    && getAfter(
      /databases/$(database)/documents/supplierCounters/default
    ).data.updatedAt == request.time;

  /*
   * Update supplier contact and payment details.
   */
  allow update: if isValidSupplierData(
      request.resource.data
    )

    && (
      /*
       * Superadmin/Admin supplier master-data
       * and status management.
       */
      (
        isSupplierManager()

        && (
          (
            onlySupplierMasterFieldsChanged()

            && request.resource.data.supplierCode
              == resource.data.supplierCode

            && request.resource.data.status
              == resource.data.status

            && request.resource.data.hasPurchaseHistory
              == resource.data.hasPurchaseHistory

            && request.resource.data.purchaseOrderCount
              == resource.data.purchaseOrderCount

            && request.resource.data.createdBy
              == resource.data.createdBy

            && request.resource.data.createdAt
              == resource.data.createdAt

            && request.resource.data.updatedBy
              == request.auth.uid

            && request.resource.data.updatedAt
              == request.time
          )

          ||

          (
            onlySupplierStatusFieldsChanged()

            && request.resource.data.status
              != resource.data.status

            && request.resource.data.keys().hasAll([
              "statusChangedBy",
              "statusChangedAt"
            ])

            && request.resource.data.statusChangedBy
              == request.auth.uid

            && request.resource.data.statusChangedAt
              == request.time

            && request.resource.data.updatedBy
              == request.auth.uid

            && request.resource.data.updatedAt
              == request.time
          )
        )
      )

      ||

      /*
       * Purchase Order submission updates the
       * supplier's permanent purchase history.
       */
      (
        canUpdateSupplierPurchaseHistory()

        && onlySupplierPurchaseHistoryFieldsChanged()

        && resource.data.status == "ACTIVE"

        && request.resource.data.status == "ACTIVE"

        && request.resource.data.hasPurchaseHistory
          == true

        && request.resource.data.purchaseOrderCount
          == resource.data.purchaseOrderCount + 1

        && request.resource.data.lastPurchaseOrderId
          is string

        && request.resource.data.lastPurchaseOrderId.size()
          >= 1

        && request.resource.data.lastPurchaseOrderNumber
          is string

        && request.resource.data.lastPurchaseOrderNumber.matches(
          "^PO-[0-9]{4}-[0-9]{6}$"
        )

        && request.resource.data.lastPurchaseOrderSubmittedAt
          == request.time

        && request.resource.data.updatedBy
          == request.auth.uid

        && request.resource.data.updatedAt
          == request.time

        && submittedPurchaseOrderMatchesSupplier(
          supplierId,
          request.resource.data.lastPurchaseOrderId,
          request.resource.data.lastPurchaseOrderNumber
        )
      )
    );

  /*
   * Supplier records remain permanent.
   */
  allow delete: if false;
}

/*
 * SUPPLIER CODE COUNTER
 */
match /supplierCounters/{counterId} {

  /*
   * The create-supplier transaction reads the
   * current supplier sequence.
   */
  allow get: if isSupplierManager();

  allow list: if false;

  /*
   * The first supplier begins at sequence 1.
   */
  allow create: if isSupplierManager()

    && counterId == "default"

    && request.resource.data.keys().hasOnly([
      "lastSequence",
      "updatedBy",
      "updatedAt"
    ])

    && request.resource.data.keys().hasAll([
      "lastSequence",
      "updatedBy",
      "updatedAt"
    ])

    && request.resource.data.lastSequence
      is int

    && request.resource.data.lastSequence
      == 1

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time;

  /*
   * Every new supplier increases the counter
   * by exactly one.
   */
  allow update: if isSupplierManager()

    && counterId == "default"

    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "lastSequence",
        "updatedBy",
        "updatedAt"
      ])

    && request.resource.data.lastSequence
      is int

    && request.resource.data.lastSequence
      == resource.data.lastSequence + 1

    && request.resource.data.lastSequence
      <= 999999

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time;

  allow delete: if false;
}

/*
 * PURCHASE ORDER ACCESS
 */
function canReadPurchaseOrders() {
  return hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF",
    "AUDITOR"
  ]);
}

function canManagePurchaseOrderDrafts() {
  return hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF"
  ]);
}

function isPurchaseOrderApprover() {
  return hasRole([
    "SUPERADMIN",
    "ADMIN"
  ]);
}

function isValidPurchaseOrderStatus(status) {
  return status in [
    "DRAFT",
    "SUBMITTED",
    "APPROVED",
    "PARTIALLY_RECEIVED",
    "RECEIVED",
    "CANCELLED"
  ];
}

function supplierHistoryUpdatedForSubmission(
  purchaseOrderId,
  supplierId,
  poNumber
) {
  let supplierBefore = get(
    /databases/$(database)/documents/suppliers/$(supplierId)
  ).data;

  let supplierAfter = getAfter(
    /databases/$(database)/documents/suppliers/$(supplierId)
  ).data;

  return supplierBefore.status == "ACTIVE"
    && supplierAfter.status == "ACTIVE"
    && supplierAfter.hasPurchaseHistory == true
    && supplierAfter.purchaseOrderCount
      == supplierBefore.purchaseOrderCount + 1
    && supplierAfter.lastPurchaseOrderId
      == purchaseOrderId
    && supplierAfter.lastPurchaseOrderNumber
      == poNumber
    && supplierAfter.lastPurchaseOrderSubmittedAt
      == request.time
    && supplierAfter.updatedBy
      == request.auth.uid
    && supplierAfter.updatedAt
      == request.time;
}


/*
 * GOODS RECEIVING ACCESS
 */
function canReadGoodsReceipts() {
  return hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF",
    "AUDITOR"
  ]);
}

function canPostGoodsReceipts() {
  return hasRole([
    "SUPERADMIN",
    "ADMIN",
    "INVENTORY_STAFF"
  ]);
}

function isValidGoodsReceiptDateKey(value) {
  return value is string
    && value.matches(
      "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    );
}

function isValidGoodsReceiptMoney(value) {
  return value is number
    && value >= 0
    && value <= 999999999999.99;
}

/*
 * Confirms that a receiving PO update points to
 * the Goods Receipt created in the same atomic
 * transaction.
 *
 * This performs one shared getAfter() call for the
 * PO header operation. Item rules intentionally use
 * local validation so large receipts do not exceed
 * Firestore rule document-access limits.
 */
function goodsReceiptMatchesPurchaseOrderUpdate(
  purchaseOrderId
) {
  let receiptAfter = getAfter(
    /databases/$(database)/documents/goodsReceipts/$(request.resource.data.lastGoodsReceiptId)
  ).data;

  return receiptAfter.purchaseOrderId
      == purchaseOrderId
    && receiptAfter.poNumber
      == resource.data.poNumber
    && receiptAfter.supplierId
      == resource.data.supplierId
    && receiptAfter.goodsReceiptNumber
      == request.resource.data.lastGoodsReceiptNumber
    && receiptAfter.referenceNumber
      == request.resource.data.lastGoodsReceiptReference
    && receiptAfter.purchaseOrderStatusBefore
      == resource.data.status
    && receiptAfter.purchaseOrderStatusAfter
      == request.resource.data.status
    && receiptAfter.totalReceivedQuantity
      == request.resource.data.totalReceivedQuantity
        - resource.data.totalReceivedQuantity
    && receiptAfter.createdBy
      == request.auth.uid
    && receiptAfter.createdAt
      == request.time;
}

/*
 * Confirms that the receipt header and its parent PO
 * move together in the same atomic transaction.
 */
function purchaseOrderMatchesGoodsReceiptCreate(
  data,
  goodsReceiptId
) {
  let purchaseOrderBefore = get(
    /databases/$(database)/documents/purchaseOrders/$(data.purchaseOrderId)
  ).data;

  let purchaseOrderAfter = getAfter(
    /databases/$(database)/documents/purchaseOrders/$(data.purchaseOrderId)
  ).data;

  return purchaseOrderBefore.poNumber
      == data.poNumber
    && purchaseOrderAfter.poNumber
      == data.poNumber
    && purchaseOrderBefore.supplierId
      == data.supplierId
    && purchaseOrderAfter.supplierId
      == data.supplierId
    && purchaseOrderBefore.status
      == data.purchaseOrderStatusBefore
    && purchaseOrderAfter.status
      == data.purchaseOrderStatusAfter
    && purchaseOrderAfter.totalReceivedQuantity
      == purchaseOrderBefore.totalReceivedQuantity
        + data.totalReceivedQuantity
    && purchaseOrderAfter.goodsReceiptCount
      == purchaseOrderBefore.goodsReceiptCount + 1
    && purchaseOrderAfter.hasReceivingHistory
      == true
    && purchaseOrderAfter.lastGoodsReceiptId
      == goodsReceiptId
    && purchaseOrderAfter.lastGoodsReceiptNumber
      == data.goodsReceiptNumber
    && purchaseOrderAfter.lastGoodsReceiptReference
      == data.referenceNumber
    && purchaseOrderAfter.lastReceivedAt
      == request.time
    && purchaseOrderAfter.updatedBy
      == request.auth.uid
    && purchaseOrderAfter.updatedAt
      == request.time;
}

function reservationMatchesGoodsReceipt(data) {
  let receiptAfter = getAfter(
    /databases/$(database)/documents/goodsReceipts/$(data.goodsReceiptId)
  ).data;

  return receiptAfter.goodsReceiptNumber
      == data.goodsReceiptNumber
    && receiptAfter.purchaseOrderId
      == data.purchaseOrderId
    && receiptAfter.poNumber
      == data.poNumber
    && receiptAfter.supplierId
      == data.supplierId
    && receiptAfter.referenceNumber
      == data.referenceNumber
    && receiptAfter.createdBy
      == request.auth.uid
    && receiptAfter.createdAt
      == request.time;
}

function isValidPurchaseOrderPaymentTerm(paymentTerm) {
  return paymentTerm in [
    "CASH_ON_DELIVERY",
    "PREPAID",
    "NET_7",
    "NET_15",
    "NET_30",
    "NET_45",
    "NET_60",
    "CUSTOM"
  ];
}

function isValidPurchaseOrderDateKey(value) {
  return value is string
    && value.matches(
      "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    );
}

function isValidOptionalPurchaseOrderDateKey(value) {
  return value is string
    && (
      value == ""
      || value.matches(
        "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
      )
    );
}

function isValidPurchaseOrderMoney(value) {
  return value is number
    && value >= 0
    && value <= 999999999999.99;
}

function purchaseOrderCounterMatchesCreate(data) {
  let counter = getAfter(
    /databases/$(database)/documents/purchaseOrderCounters/$(string(data.poYear))
  ).data;

  return data.poSequence is int
    && data.poSequence >= 1
    && data.poSequence <= 999999
    && int(data.poNumber[3:7]) == data.poYear
    && int(data.poNumber[8:14]) == data.poSequence
    && counter.year == data.poYear
    && counter.lastSequence == data.poSequence
    && counter.updatedBy == request.auth.uid
    && counter.updatedAt == request.time;
}

function isValidPurchaseOrderHeader(data) {
  return data.keys().hasOnly([
      "poNumber",
      "poYear",
      "poSequence",

      "supplierId",
      "supplierCode",
      "supplierName",
      "supplierAddress",
      "supplierTin",
      "supplierPaymentTerm",
      "supplierCustomPaymentTerms",

      "orderDate",
      "orderDateKey",
      "expectedDeliveryDate",
      "expectedDeliveryDateKey",

      "status",

      "itemCount",
      "itemProductIds",

      "totalOrderedQuantity",
      "totalReceivedQuantity",

      "subtotal",
      "discountAmount",
      "taxAmount",
      "shippingAmount",
      "grandTotal",

      "hasReceivingHistory",
      "goodsReceiptCount",

      "notes",
      "revision",

      "submittedBy",
      "submittedByName",
      "submittedAt",

      "approvedBy",
      "approvedByName",
      "approvedAt",

      "cancellationReason",
      "cancelledBy",
      "cancelledByName",
      "cancelledAt",

      "createdBy",
      "createdAt",
      "updatedBy",
      "updatedAt"
    ])

    && data.keys().hasAll([
      "poNumber",
      "poYear",

      "supplierId",
      "supplierCode",
      "supplierName",
      "supplierAddress",
      "supplierTin",
      "supplierPaymentTerm",
      "supplierCustomPaymentTerms",

      "orderDate",
      "orderDateKey",
      "expectedDeliveryDate",
      "expectedDeliveryDateKey",

      "status",

      "itemCount",
      "itemProductIds",

      "totalOrderedQuantity",
      "totalReceivedQuantity",

      "subtotal",
      "discountAmount",
      "taxAmount",
      "shippingAmount",
      "grandTotal",

      "hasReceivingHistory",
      "goodsReceiptCount",

      "notes",
      "revision",

      "createdBy",
      "createdAt",
      "updatedBy",
      "updatedAt"
    ])

    && data.poNumber is string
    && data.poNumber.matches(
      "^PO-[0-9]{4}-[0-9]{6}$"
    )

    && data.poYear is int
    && data.poYear >= 2000
    && data.poYear <= 9999

    && (
      !data.keys().hasAny([
        "poSequence"
      ])
      || (
        data.poSequence is int
        && data.poSequence >= 1
        && data.poSequence <= 999999
      )
    )

    && data.supplierId is string
    && data.supplierId.size() >= 1

    && data.supplierCode is string
    && data.supplierCode.size() >= 1
    && data.supplierCode.size() <= 30

    && data.supplierName is string
    && data.supplierName.size() >= 2
    && data.supplierName.size() <= 150

    && data.supplierAddress is string
    && data.supplierAddress.size() <= 300

    && data.supplierTin is string
    && data.supplierTin.size() <= 50

    && isValidPurchaseOrderPaymentTerm(
      data.supplierPaymentTerm
    )

    && data.supplierCustomPaymentTerms is string
    && data.supplierCustomPaymentTerms.size() <= 100

    && data.orderDate is timestamp

    && isValidPurchaseOrderDateKey(
      data.orderDateKey
    )

    && (
      data.expectedDeliveryDate == null
      || data.expectedDeliveryDate is timestamp
    )

    && isValidOptionalPurchaseOrderDateKey(
      data.expectedDeliveryDateKey
    )

    && (
      data.expectedDeliveryDateKey == ""
      || data.expectedDeliveryDateKey
        >= data.orderDateKey
    )

    && isValidPurchaseOrderStatus(
      data.status
    )

    && data.itemCount is int
    && data.itemCount >= 1
    && data.itemCount <= 100

    && data.itemProductIds is list
    && data.itemProductIds.size()
      == data.itemCount

    && data.totalOrderedQuantity is int
    && data.totalOrderedQuantity >= 1

    && data.totalReceivedQuantity is int
    && data.totalReceivedQuantity == 0

    && isValidPurchaseOrderMoney(
      data.subtotal
    )

    && isValidPurchaseOrderMoney(
      data.discountAmount
    )

    && data.discountAmount
      <= data.subtotal

    && isValidPurchaseOrderMoney(
      data.taxAmount
    )

    && isValidPurchaseOrderMoney(
      data.shippingAmount
    )

    && isValidPurchaseOrderMoney(
      data.grandTotal
    )

    && data.grandTotal
      >= (
        data.subtotal
        - data.discountAmount
        + data.taxAmount
        + data.shippingAmount
        - 0.01
      )

    && data.grandTotal
      <= (
        data.subtotal
        - data.discountAmount
        + data.taxAmount
        + data.shippingAmount
        + 0.01
      )

    && data.hasReceivingHistory is bool
    && data.hasReceivingHistory == false

    && data.goodsReceiptCount is int
    && data.goodsReceiptCount == 0

    && data.notes is string
    && data.notes.size() <= 1000

    && data.revision is int
    && data.revision >= 1

    && data.createdBy is string
    && data.createdBy.size() >= 1

    && data.createdAt is timestamp

    && data.updatedBy is string
    && data.updatedBy.size() >= 1

    && data.updatedAt is timestamp

    /*
     * Validate the selected supplier snapshot.
     */
    && exists(
      /databases/$(database)/documents/suppliers/$(data.supplierId)
    )

    && get(
      /databases/$(database)/documents/suppliers/$(data.supplierId)
    ).data.status == "ACTIVE"

    && data.supplierCode
      == get(
        /databases/$(database)/documents/suppliers/$(data.supplierId)
      ).data.supplierCode

    && data.supplierName
      == get(
        /databases/$(database)/documents/suppliers/$(data.supplierId)
      ).data.name;
}

function isValidPurchaseOrderItem(
  data,
  purchaseOrderId,
  itemId
) {
  return data.keys().hasOnly([
      "purchaseOrderId",
      "poNumber",
      "poStatus",

      "productId",
      "productName",
      "productSku",
      "barcode",

      "category",
      "categoryCode",

      "unitCode",
      "unitName",
      "unitAbbreviation",

      "orderedQuantity",
      "receivedQuantity",
      "remainingQuantity",

      "unitCost",
      "lineTotal",

      "createdBy",
      "createdAt",
      "updatedBy",
      "updatedAt"
    ])

    && data.keys().hasAll([
      "purchaseOrderId",
      "poNumber",
      "poStatus",

      "productId",
      "productName",
      "productSku",
      "barcode",

      "category",
      "categoryCode",

      "unitCode",
      "unitName",
      "unitAbbreviation",

      "orderedQuantity",
      "receivedQuantity",
      "remainingQuantity",

      "unitCost",
      "lineTotal",

      "createdBy",
      "createdAt",
      "updatedBy",
      "updatedAt"
    ])

    && data.purchaseOrderId
      == purchaseOrderId

    && data.productId
      == itemId

    && data.poNumber is string
    && data.poNumber.matches(
      "^PO-[0-9]{4}-[0-9]{6}$"
    )

    && isValidPurchaseOrderStatus(
      data.poStatus
    )

    && data.productName is string
    && data.productName.size() >= 1
    && data.productName.size() <= 150

    && data.productSku is string
    && data.productSku.size() >= 2
    && data.productSku.size() <= 50

    && data.barcode is string
    && data.barcode.size() <= 100

    && data.category is string
    && data.category.size() >= 1
    && data.category.size() <= 150

    && data.categoryCode is string
    && data.categoryCode.size() >= 1
    && data.categoryCode.size() <= 50

    && data.unitCode is string
    && data.unitCode.size() >= 1
    && data.unitCode.size() <= 50

    && data.unitName is string
    && data.unitName.size() >= 1
    && data.unitName.size() <= 100

    && data.unitAbbreviation is string
    && data.unitAbbreviation.size() >= 1
    && data.unitAbbreviation.size() <= 10

    && data.orderedQuantity is int
    && data.orderedQuantity >= 1
    && data.orderedQuantity <= 999999999

    && data.receivedQuantity is int
    && data.receivedQuantity == 0

    && data.remainingQuantity is int
    && data.remainingQuantity
      == data.orderedQuantity

    && data.unitCost is number
    && data.unitCost >= 0
    && data.unitCost <= 999999999

    && isValidPurchaseOrderMoney(
      data.lineTotal
    )

    && data.lineTotal
      >= (
        data.orderedQuantity
        * data.unitCost
        - 0.01
      )

    && data.lineTotal
      <= (
        data.orderedQuantity
        * data.unitCost
        + 0.01
      )

    && data.createdBy is string
    && data.createdBy.size() >= 1

    && data.createdAt is timestamp

    && data.updatedBy is string
    && data.updatedBy.size() >= 1

    && data.updatedAt is timestamp;
}


/*
 * PURCHASE ORDER HEADERS
 */
match /purchaseOrders/{purchaseOrderId} {

  allow get, list: if canReadPurchaseOrders();

  /*
   * Create a new Draft Purchase Order.
   */
  allow create: if canManagePurchaseOrderDrafts()

    && request.resource.data.status == "DRAFT"

    && isValidPurchaseOrderHeader(
      request.resource.data
    )

    && request.resource.data.createdBy
      == request.auth.uid

    && request.resource.data.createdAt
      == request.time

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time

    && request.resource.data.revision
      == 1

    && request.resource.data.keys().hasAll([
      "poSequence"
    ])

    && purchaseOrderCounterMatchesCreate(
      request.resource.data
    )

    && !request.resource.data.keys().hasAny([
      "submittedBy",
      "submittedByName",
      "submittedAt",
      "approvedBy",
      "approvedByName",
      "approvedAt",
      "cancellationReason",
      "cancelledBy",
      "cancelledByName",
      "cancelledAt"
    ]);

  /*
   * Only Draft Purchase Orders may be edited.
   */
  allow update: if canManagePurchaseOrderDrafts()

    && resource.data.status
      == "DRAFT"

    && request.resource.data.status
      == "DRAFT"

    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "supplierId",
        "supplierCode",
        "supplierName",
        "supplierAddress",
        "supplierTin",
        "supplierPaymentTerm",
        "supplierCustomPaymentTerms",

        "orderDate",
        "orderDateKey",
        "expectedDeliveryDate",
        "expectedDeliveryDateKey",

        "itemCount",
        "itemProductIds",
        "totalOrderedQuantity",

        "subtotal",
        "discountAmount",
        "taxAmount",
        "shippingAmount",
        "grandTotal",

        "notes",
        "revision",

        "updatedBy",
        "updatedAt"
      ])

    && isValidPurchaseOrderHeader(
      request.resource.data
    )

    /*
     * Permanent Purchase Order fields.
     */
    && request.resource.data.poNumber
      == resource.data.poNumber

    && request.resource.data.poYear
      == resource.data.poYear

    && request.resource.data.get(
      "poSequence",
      0
    ) == resource.data.get(
      "poSequence",
      0
    )

    && request.resource.data.createdBy
      == resource.data.createdBy

    && request.resource.data.createdAt
      == resource.data.createdAt

    && request.resource.data.totalReceivedQuantity
      == resource.data.totalReceivedQuantity

    && request.resource.data.hasReceivingHistory
      == resource.data.hasReceivingHistory

    && request.resource.data.goodsReceiptCount
      == resource.data.goodsReceiptCount

    && request.resource.data.revision
      == resource.data.revision + 1

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time;

  /*
   * Submit a Draft Purchase Order for approval.
   */
  allow update: if canManagePurchaseOrderDrafts()

    && resource.data.status == "DRAFT"

    && request.resource.data.status == "SUBMITTED"

    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "status",
        "submittedBy",
        "submittedByName",
        "submittedAt",
        "revision",
        "updatedBy",
        "updatedAt"
      ])

    && request.resource.data.submittedBy
      == request.auth.uid

    && request.resource.data.submittedByName
      is string

    && request.resource.data.submittedByName.size()
      >= 1

    && request.resource.data.submittedByName.size()
      <= 150

    && request.resource.data.submittedAt
      == request.time

    && request.resource.data.revision
      == resource.data.revision + 1

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time

    && supplierHistoryUpdatedForSubmission(
      purchaseOrderId,
      resource.data.supplierId,
      resource.data.poNumber
    );

  /*
   * Approve a Submitted Purchase Order.
   */
  allow update: if isPurchaseOrderApprover()

    && resource.data.status == "SUBMITTED"

    && request.resource.data.status == "APPROVED"

    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "status",
        "approvedBy",
        "approvedByName",
        "approvedAt",
        "revision",
        "updatedBy",
        "updatedAt"
      ])

    && request.resource.data.approvedBy
      == request.auth.uid

    && request.resource.data.approvedByName
      is string

    && request.resource.data.approvedByName.size()
      >= 1

    && request.resource.data.approvedByName.size()
      <= 150

    && request.resource.data.approvedAt
      == request.time

    && request.resource.data.revision
      == resource.data.revision + 1

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time;

  /*
   * Post a Goods Receipt against an Approved or
   * Partially Received Purchase Order.
   */
  allow update: if canPostGoodsReceipts()

    && resource.data.status in [
      "APPROVED",
      "PARTIALLY_RECEIVED"
    ]

    && request.resource.data.status in [
      "PARTIALLY_RECEIVED",
      "RECEIVED"
    ]

    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "status",
        "totalReceivedQuantity",
        "hasReceivingHistory",
        "goodsReceiptCount",
        "lastGoodsReceiptId",
        "lastGoodsReceiptNumber",
        "lastGoodsReceiptReference",
        "lastReceivedAt",
        "revision",
        "updatedBy",
        "updatedAt"
      ])

    && request.resource.data.totalReceivedQuantity
      is int

    && request.resource.data.totalReceivedQuantity
      > resource.data.totalReceivedQuantity

    && request.resource.data.totalReceivedQuantity
      <= resource.data.totalOrderedQuantity

    && (
      (
        request.resource.data.totalReceivedQuantity
          == resource.data.totalOrderedQuantity
        && request.resource.data.status
          == "RECEIVED"
      )
      ||
      (
        request.resource.data.totalReceivedQuantity
          < resource.data.totalOrderedQuantity
        && request.resource.data.status
          == "PARTIALLY_RECEIVED"
      )
    )

    && request.resource.data.hasReceivingHistory
      == true

    && request.resource.data.goodsReceiptCount
      == resource.data.goodsReceiptCount + 1

    && request.resource.data.lastGoodsReceiptId
      is string

    && request.resource.data.lastGoodsReceiptId.size()
      >= 1

    && request.resource.data.lastGoodsReceiptId.size()
      <= 128

    && request.resource.data.lastGoodsReceiptNumber
      is string

    && request.resource.data.lastGoodsReceiptNumber.matches(
      "^GRN-[0-9]{4}-[0-9]{6}$"
    )

    && request.resource.data.lastGoodsReceiptReference
      is string

    && request.resource.data.lastGoodsReceiptReference.size()
      >= 1

    && request.resource.data.lastGoodsReceiptReference.size()
      <= 100

    && request.resource.data.lastReceivedAt
      == request.time

    && request.resource.data.revision
      == resource.data.revision + 1

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time

    && goodsReceiptMatchesPurchaseOrderUpdate(
      purchaseOrderId
    );

  /*
   * Cancel a Draft, Submitted, or Approved PO
   * before any goods receiving takes place.
   */
  allow update: if isPurchaseOrderApprover()

    && resource.data.status in [
      "DRAFT",
      "SUBMITTED",
      "APPROVED"
    ]

    && request.resource.data.status == "CANCELLED"

    && resource.data.hasReceivingHistory == false

    && resource.data.totalReceivedQuantity == 0

    && resource.data.goodsReceiptCount == 0

    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "status",
        "cancellationReason",
        "cancelledBy",
        "cancelledByName",
        "cancelledAt",
        "revision",
        "updatedBy",
        "updatedAt"
      ])

    && request.resource.data.cancellationReason
      is string

    && request.resource.data.cancellationReason.size()
      >= 1

    && request.resource.data.cancellationReason.size()
      <= 500

    && request.resource.data.cancelledBy
      == request.auth.uid

    && request.resource.data.cancelledByName
      is string

    && request.resource.data.cancelledByName.size()
      >= 1

    && request.resource.data.cancelledByName.size()
      <= 150

    && request.resource.data.cancelledAt
      == request.time

    && request.resource.data.revision
      == resource.data.revision + 1

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time;

  /*
   * Purchase Order headers remain permanent.
   */
  allow delete: if false;

  /*
   * PURCHASE ORDER ITEMS
   */
  match /items/{itemId} {

    allow get, list: if canReadPurchaseOrders();

    allow create: if canManagePurchaseOrderDrafts()

      && request.resource.data.poStatus == "DRAFT"

      && isValidPurchaseOrderItem(
        request.resource.data,
        purchaseOrderId,
        itemId
      )

      && request.resource.data.createdBy
        == request.auth.uid

      && request.resource.data.createdAt
        == request.time

      && request.resource.data.updatedBy
        == request.auth.uid

      && request.resource.data.updatedAt
        == request.time;

    allow update: if canManagePurchaseOrderDrafts()

      && resource.data.poStatus
        == "DRAFT"

      && request.resource.data.poStatus
        == "DRAFT"

      && request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          "productName",
          "productSku",
          "barcode",

          "category",
          "categoryCode",

          "unitCode",
          "unitName",
          "unitAbbreviation",

          "orderedQuantity",
          "remainingQuantity",

          "unitCost",
          "lineTotal",

          "updatedBy",
          "updatedAt"
        ])

      && isValidPurchaseOrderItem(
        request.resource.data,
        purchaseOrderId,
        itemId
      )

      /*
       * Permanent item identifiers.
       */
      && request.resource.data.purchaseOrderId
        == resource.data.purchaseOrderId

      && request.resource.data.poNumber
        == resource.data.poNumber

      && request.resource.data.productId
        == resource.data.productId

      && request.resource.data.receivedQuantity
        == resource.data.receivedQuantity

      && request.resource.data.createdBy
        == resource.data.createdBy

      && request.resource.data.createdAt
        == resource.data.createdAt

      && request.resource.data.updatedBy
        == request.auth.uid

      && request.resource.data.updatedAt
        == request.time;

    /*
     * Keep item snapshots synchronized when the
     * parent PO moves through its workflow.
     */
    allow update: if canManagePurchaseOrderDrafts()

      && resource.data.poStatus == "DRAFT"

      && request.resource.data.poStatus == "SUBMITTED"

      && request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          "poStatus",
          "updatedBy",
          "updatedAt"
        ])

      && isValidPurchaseOrderItem(
        request.resource.data,
        purchaseOrderId,
        itemId
      )

      && request.resource.data.updatedBy
        == request.auth.uid

      && request.resource.data.updatedAt
        == request.time;

    allow update: if isPurchaseOrderApprover()

      && resource.data.poStatus == "SUBMITTED"

      && request.resource.data.poStatus == "APPROVED"

      && request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          "poStatus",
          "updatedBy",
          "updatedAt"
        ])

      && isValidPurchaseOrderItem(
        request.resource.data,
        purchaseOrderId,
        itemId
      )

      && request.resource.data.updatedBy
        == request.auth.uid

      && request.resource.data.updatedAt
        == request.time;

    allow update: if isPurchaseOrderApprover()

      && resource.data.poStatus in [
        "DRAFT",
        "SUBMITTED",
        "APPROVED"
      ]

      && request.resource.data.poStatus == "CANCELLED"

      && request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          "poStatus",
          "updatedBy",
          "updatedAt"
        ])

      && isValidPurchaseOrderItem(
        request.resource.data,
        purchaseOrderId,
        itemId
      )

      && request.resource.data.updatedBy
        == request.auth.uid

      && request.resource.data.updatedAt
        == request.time;

    /*
     * Receive quantity against one PO item.
     */
    allow update: if canPostGoodsReceipts()

      && resource.data.poStatus in [
        "APPROVED",
        "PARTIALLY_RECEIVED"
      ]

      && request.resource.data.poStatus in [
        "PARTIALLY_RECEIVED",
        "RECEIVED"
      ]

      && request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          "receivedQuantity",
          "remainingQuantity",
          "poStatus",
          "lastReceivedQuantity",
          "lastReceivedUnitCost",
          "lastGoodsReceiptId",
          "lastGoodsReceiptNumber",
          "lastReceivedAt",
          "updatedBy",
          "updatedAt"
        ])

      && request.resource.data.receivedQuantity
        is int

      && request.resource.data.receivedQuantity
        > resource.data.receivedQuantity

      && request.resource.data.receivedQuantity
        <= resource.data.orderedQuantity

      && request.resource.data.remainingQuantity
        is int

      && request.resource.data.remainingQuantity
        == request.resource.data.orderedQuantity
          - request.resource.data.receivedQuantity

      && request.resource.data.lastReceivedQuantity
        is int

      && request.resource.data.lastReceivedQuantity
        == request.resource.data.receivedQuantity
          - resource.data.receivedQuantity

      && request.resource.data.lastReceivedQuantity
        >= 1

      && request.resource.data.lastReceivedQuantity
        <= resource.data.remainingQuantity

      && request.resource.data.lastReceivedUnitCost
        is number

      && request.resource.data.lastReceivedUnitCost
        >= 0

      && request.resource.data.lastReceivedUnitCost
        <= 999999999

      && request.resource.data.lastGoodsReceiptId
        is string

      && request.resource.data.lastGoodsReceiptId.size()
        >= 1

      && request.resource.data.lastGoodsReceiptId.size()
        <= 128

      && request.resource.data.lastGoodsReceiptNumber
        is string

      && request.resource.data.lastGoodsReceiptNumber.matches(
        "^GRN-[0-9]{4}-[0-9]{6}$"
      )

      && request.resource.data.lastReceivedAt
        == request.time

      && (
        request.resource.data.poStatus
          == "PARTIALLY_RECEIVED"
        || request.resource.data.remainingQuantity
          == 0
      )

      && request.resource.data.updatedBy
        == request.auth.uid

      && request.resource.data.updatedAt
        == request.time;

    /*
     * Synchronize an unselected PO item's status
     * when the parent PO moves to PARTIALLY_RECEIVED
     * or RECEIVED.
     */
    allow update: if canPostGoodsReceipts()

      && resource.data.poStatus in [
        "APPROVED",
        "PARTIALLY_RECEIVED"
      ]

      && request.resource.data.poStatus in [
        "PARTIALLY_RECEIVED",
        "RECEIVED"
      ]

      && request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly([
          "poStatus",
          "updatedBy",
          "updatedAt"
        ])

      && (
        request.resource.data.poStatus
          == "PARTIALLY_RECEIVED"
        || resource.data.remainingQuantity
          == 0
      )

      && request.resource.data.updatedBy
        == request.auth.uid

      && request.resource.data.updatedAt
        == request.time;

    /*
     * Items may only be removed while Draft.
     */
    allow delete: if canManagePurchaseOrderDrafts()
      && resource.data.poStatus == "DRAFT";
  }
}


/*
 * PURCHASE ORDER NUMBER COUNTERS
 */
match /purchaseOrderCounters/{counterId} {

  allow get: if canManagePurchaseOrderDrafts();

  allow list: if false;

  allow create: if canManagePurchaseOrderDrafts()

    && counterId.matches(
      "^[0-9]{4}$"
    )

    && request.resource.data.keys().hasOnly([
      "year",
      "lastSequence",
      "updatedBy",
      "updatedAt"
    ])

    && request.resource.data.keys().hasAll([
      "year",
      "lastSequence",
      "updatedBy",
      "updatedAt"
    ])

    && request.resource.data.year is int

    && request.resource.data.year >= 2000

    && request.resource.data.year <= 9999

    && request.resource.data.lastSequence is int

    && request.resource.data.lastSequence
      == 1

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time;

  allow update: if canManagePurchaseOrderDrafts()

    && counterId.matches(
      "^[0-9]{4}$"
    )

    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "year",
        "lastSequence",
        "updatedBy",
        "updatedAt"
      ])

    && request.resource.data.year
      == resource.data.year

    && request.resource.data.lastSequence
      is int

    && request.resource.data.lastSequence
      == resource.data.lastSequence + 1

    && request.resource.data.lastSequence
      <= 999999

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time;

  allow delete: if false;
}




function goodsReceiptCounterMatchesCreate(data) {
  let counter = getAfter(
    /databases/$(database)/documents/goodsReceiptCounters/$(string(data.goodsReceiptYear))
  ).data;

  return data.goodsReceiptSequence is int
    && data.goodsReceiptSequence >= 1
    && data.goodsReceiptSequence <= 999999
    && int(data.goodsReceiptNumber[4:8])
      == data.goodsReceiptYear
    && int(data.goodsReceiptNumber[9:15])
      == data.goodsReceiptSequence
    && counter.year == data.goodsReceiptYear
    && counter.lastSequence
      == data.goodsReceiptSequence
    && counter.updatedBy == request.auth.uid
    && counter.updatedAt == request.time;
}

/*
 * GOODS RECEIPT HEADERS
 */
match /goodsReceipts/{goodsReceiptId} {

  allow get, list: if canReadGoodsReceipts();

  allow create: if canPostGoodsReceipts()

    && request.resource.data.keys().hasOnly([
      "goodsReceiptNumber",
      "goodsReceiptYear",
      "goodsReceiptSequence",
      "purchaseOrderId",
      "poNumber",
      "supplierId",
      "supplierCode",
      "supplierName",
      "referenceNumber",
      "dateReceived",
      "dateReceivedKey",
      "status",
      "itemCount",
      "totalReceivedQuantity",
      "totalValue",
      "remarks",
      "purchaseOrderStatusBefore",
      "purchaseOrderStatusAfter",
      "receivedBy",
      "receivedByName",
      "createdBy",
      "createdAt"
    ])

    && request.resource.data.keys().hasAll([
      "goodsReceiptNumber",
      "goodsReceiptYear",
      "goodsReceiptSequence",
      "purchaseOrderId",
      "poNumber",
      "supplierId",
      "supplierCode",
      "supplierName",
      "referenceNumber",
      "dateReceived",
      "dateReceivedKey",
      "status",
      "itemCount",
      "totalReceivedQuantity",
      "totalValue",
      "remarks",
      "purchaseOrderStatusBefore",
      "purchaseOrderStatusAfter",
      "receivedBy",
      "receivedByName",
      "createdBy",
      "createdAt"
    ])

    && request.resource.data.goodsReceiptNumber
      is string

    && request.resource.data.goodsReceiptNumber.matches(
      "^GRN-[0-9]{4}-[0-9]{6}$"
    )

    && request.resource.data.goodsReceiptYear
      is int

    && request.resource.data.goodsReceiptYear
      >= 2000

    && request.resource.data.goodsReceiptYear
      <= 9999

    && request.resource.data.goodsReceiptSequence
      is int

    && request.resource.data.goodsReceiptSequence
      >= 1

    && request.resource.data.goodsReceiptSequence
      <= 999999

    && request.resource.data.purchaseOrderId
      is string

    && request.resource.data.purchaseOrderId.size()
      >= 1

    && request.resource.data.purchaseOrderId.size()
      <= 128

    && request.resource.data.poNumber
      is string

    && request.resource.data.poNumber.matches(
      "^PO-[0-9]{4}-[0-9]{6}$"
    )

    && request.resource.data.supplierId
      is string

    && request.resource.data.supplierId.size()
      >= 1

    && request.resource.data.supplierCode
      is string

    && request.resource.data.supplierCode.size()
      >= 1

    && request.resource.data.supplierCode.size()
      <= 30

    && request.resource.data.supplierName
      is string

    && request.resource.data.supplierName.size()
      >= 2

    && request.resource.data.supplierName.size()
      <= 150

    && request.resource.data.referenceNumber
      is string

    && request.resource.data.referenceNumber.size()
      >= 1

    && request.resource.data.referenceNumber.size()
      <= 100

    && request.resource.data.dateReceived
      is timestamp

    && isValidGoodsReceiptDateKey(
      request.resource.data.dateReceivedKey
    )

    && request.resource.data.status
      == "COMPLETED"

    && request.resource.data.itemCount
      is int

    && request.resource.data.itemCount
      >= 1

    && request.resource.data.itemCount
      <= 30

    && request.resource.data.totalReceivedQuantity
      is int

    && request.resource.data.totalReceivedQuantity
      >= 1

    && request.resource.data.totalReceivedQuantity
      <= 999999999

    && isValidGoodsReceiptMoney(
      request.resource.data.totalValue
    )

    && request.resource.data.remarks
      is string

    && request.resource.data.remarks.size()
      <= 500

    && request.resource.data.purchaseOrderStatusBefore in [
      "APPROVED",
      "PARTIALLY_RECEIVED"
    ]

    && request.resource.data.purchaseOrderStatusAfter in [
      "PARTIALLY_RECEIVED",
      "RECEIVED"
    ]

    && request.resource.data.receivedBy
      == request.auth.uid

    && request.resource.data.receivedByName
      is string

    && request.resource.data.receivedByName.size()
      >= 1

    && request.resource.data.receivedByName.size()
      <= 150

    && request.resource.data.createdBy
      == request.auth.uid

    && request.resource.data.createdAt
      == request.time

    && goodsReceiptCounterMatchesCreate(
      request.resource.data
    )

    && purchaseOrderMatchesGoodsReceiptCreate(
      request.resource.data,
      goodsReceiptId
    );

  allow update, delete: if false;

  /*
   * GOODS RECEIPT ITEMS
   */
  match /items/{itemId} {

    allow get, list: if canReadGoodsReceipts();

    allow create: if canPostGoodsReceipts()

      && request.resource.data.keys().hasOnly([
        "goodsReceiptId",
        "goodsReceiptNumber",
        "purchaseOrderId",
        "poNumber",
        "productId",
        "productName",
        "productSku",
        "category",
        "categoryCode",
        "unitCode",
        "unitName",
        "unitAbbreviation",
        "orderedQuantity",
        "previouslyReceivedQuantity",
        "quantityReceived",
        "remainingQuantity",
        "unitCost",
        "lineTotal",
        "stockMovementId",
        "createdBy",
        "createdAt"
      ])

      && request.resource.data.keys().hasAll([
        "goodsReceiptId",
        "goodsReceiptNumber",
        "purchaseOrderId",
        "poNumber",
        "productId",
        "productName",
        "productSku",
        "category",
        "categoryCode",
        "unitCode",
        "unitName",
        "unitAbbreviation",
        "orderedQuantity",
        "previouslyReceivedQuantity",
        "quantityReceived",
        "remainingQuantity",
        "unitCost",
        "lineTotal",
        "stockMovementId",
        "createdBy",
        "createdAt"
      ])

      && request.resource.data.goodsReceiptId
        == goodsReceiptId

      && request.resource.data.goodsReceiptNumber
        is string

      && request.resource.data.goodsReceiptNumber.matches(
        "^GRN-[0-9]{4}-[0-9]{6}$"
      )

      && request.resource.data.purchaseOrderId
        is string

      && request.resource.data.purchaseOrderId.size()
        >= 1

      && request.resource.data.poNumber
        is string

      && request.resource.data.poNumber.matches(
        "^PO-[0-9]{4}-[0-9]{6}$"
      )

      && request.resource.data.productId
        == itemId

      && request.resource.data.productName
        is string

      && request.resource.data.productName.size()
        >= 1

      && request.resource.data.productName.size()
        <= 150

      && request.resource.data.productSku
        is string

      && request.resource.data.productSku.size()
        >= 2

      && request.resource.data.productSku.size()
        <= 50

      && request.resource.data.category
        is string

      && request.resource.data.category.size()
        >= 1

      && request.resource.data.category.size()
        <= 150

      && request.resource.data.categoryCode
        is string

      && request.resource.data.categoryCode.size()
        >= 1

      && request.resource.data.categoryCode.size()
        <= 50

      && request.resource.data.unitCode
        is string

      && request.resource.data.unitCode.size()
        >= 1

      && request.resource.data.unitCode.size()
        <= 50

      && request.resource.data.unitName
        is string

      && request.resource.data.unitName.size()
        >= 1

      && request.resource.data.unitName.size()
        <= 100

      && request.resource.data.unitAbbreviation
        is string

      && request.resource.data.unitAbbreviation.size()
        >= 1

      && request.resource.data.unitAbbreviation.size()
        <= 10

      && request.resource.data.orderedQuantity
        is int

      && request.resource.data.orderedQuantity
        >= 1

      && request.resource.data.previouslyReceivedQuantity
        is int

      && request.resource.data.previouslyReceivedQuantity
        >= 0

      && request.resource.data.quantityReceived
        is int

      && request.resource.data.quantityReceived
        >= 1

      && request.resource.data.remainingQuantity
        is int

      && request.resource.data.remainingQuantity
        >= 0

      && request.resource.data.previouslyReceivedQuantity
        + request.resource.data.quantityReceived
        + request.resource.data.remainingQuantity
        == request.resource.data.orderedQuantity

      && request.resource.data.unitCost
        is number

      && request.resource.data.unitCost
        >= 0

      && request.resource.data.unitCost
        <= 999999999

      && isValidGoodsReceiptMoney(
        request.resource.data.lineTotal
      )

      && request.resource.data.lineTotal
        >= request.resource.data.quantityReceived
          * request.resource.data.unitCost - 0.01

      && request.resource.data.lineTotal
        <= request.resource.data.quantityReceived
          * request.resource.data.unitCost + 0.01

      && request.resource.data.stockMovementId
        is string

      && request.resource.data.stockMovementId.size()
        >= 1

      && request.resource.data.stockMovementId.size()
        <= 128

      && request.resource.data.createdBy
        == request.auth.uid

      && request.resource.data.createdAt
        == request.time;

    allow update, delete: if false;
  }
}

/*
 * GOODS RECEIPT NUMBER COUNTERS
 */
match /goodsReceiptCounters/{counterId} {

  allow get: if canPostGoodsReceipts();

  allow list: if false;

  allow create: if canPostGoodsReceipts()

    && counterId.matches(
      "^[0-9]{4}$"
    )

    && request.resource.data.keys().hasOnly([
      "year",
      "lastSequence",
      "updatedBy",
      "updatedAt"
    ])

    && request.resource.data.keys().hasAll([
      "year",
      "lastSequence",
      "updatedBy",
      "updatedAt"
    ])

    && request.resource.data.year
      is int

    && request.resource.data.year
      >= 2000

    && request.resource.data.year
      <= 9999

    && request.resource.data.lastSequence
      == 1

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time;

  allow update: if canPostGoodsReceipts()

    && counterId.matches(
      "^[0-9]{4}$"
    )

    && request.resource.data
      .diff(resource.data)
      .affectedKeys()
      .hasOnly([
        "year",
        "lastSequence",
        "updatedBy",
        "updatedAt"
      ])

    && request.resource.data.year
      == resource.data.year

    && request.resource.data.lastSequence
      is int

    && request.resource.data.lastSequence
      == resource.data.lastSequence + 1

    && request.resource.data.lastSequence
      <= 999999

    && request.resource.data.updatedBy
      == request.auth.uid

    && request.resource.data.updatedAt
      == request.time;

  allow delete: if false;
}

/*
 * SUPPLIER REFERENCE RESERVATIONS
 */
match /goodsReceiptReferenceReservations/{reservationId} {

  allow get: if canPostGoodsReceipts();

  allow list: if false;

  allow create: if canPostGoodsReceipts()

    && request.resource.data.keys().hasOnly([
      "supplierId",
      "supplierCode",
      "supplierName",
      "referenceNumber",
      "purchaseOrderId",
      "poNumber",
      "goodsReceiptId",
      "goodsReceiptNumber",
      "createdBy",
      "createdAt"
    ])

    && request.resource.data.keys().hasAll([
      "supplierId",
      "supplierCode",
      "supplierName",
      "referenceNumber",
      "purchaseOrderId",
      "poNumber",
      "goodsReceiptId",
      "goodsReceiptNumber",
      "createdBy",
      "createdAt"
    ])

    && request.resource.data.supplierId
      is string

    && request.resource.data.supplierId.size()
      >= 1

    && request.resource.data.supplierCode
      is string

    && request.resource.data.supplierCode.size()
      >= 1

    && request.resource.data.supplierCode.size()
      <= 30

    && request.resource.data.supplierName
      is string

    && request.resource.data.supplierName.size()
      >= 2

    && request.resource.data.supplierName.size()
      <= 150

    && request.resource.data.referenceNumber
      is string

    && request.resource.data.referenceNumber.size()
      >= 1

    && request.resource.data.referenceNumber.size()
      <= 100

    && request.resource.data.purchaseOrderId
      is string

    && request.resource.data.purchaseOrderId.size()
      >= 1

    && request.resource.data.poNumber
      is string

    && request.resource.data.poNumber.matches(
      "^PO-[0-9]{4}-[0-9]{6}$"
    )

    && request.resource.data.goodsReceiptId
      is string

    && request.resource.data.goodsReceiptId.size()
      >= 1

    && request.resource.data.goodsReceiptId.size()
      <= 128

    && request.resource.data.goodsReceiptNumber
      is string

    && request.resource.data.goodsReceiptNumber.matches(
      "^GRN-[0-9]{4}-[0-9]{6}$"
    )

    && request.resource.data.createdBy
      == request.auth.uid

    && request.resource.data.createdAt
      == request.time

    && reservationId
      == hashing.sha256(
        (
          request.resource.data.supplierId
          + "__"
          + request.resource.data.referenceNumber
        ).toUtf8()
      ).toHexString()

    && reservationMatchesGoodsReceipt(
      request.resource.data
    );

  allow update, delete: if false;
}

    /*
     * DENY EVERY COLLECTION NOT EXPLICITLY LISTED ABOVE.
     */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}